#include<iostream>
#include<string>
using namespace std;

int main(){
    string s;
    getline(cin, s); 

    if(!s.empty() && s[0] != ' ')
        s[0] = toupper(s[0]);

    for(int i = 1; i < s.length(); i++){
        if(s[i-1] == ' ' && s[i] != ' ')
            s[i] = toupper(s[i]);
    }
    string word = "";
    for(int i = 0; i < s.length(); i++){
        if(s[i] != ' '){
            word += s[i];
        } else {
            if(!word.empty()){
                cout << word << endl;
                word = "";
            }
        }
    }
    if(!word.empty())
        cout << word << endl;

    return 0;
}
